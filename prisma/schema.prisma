generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String?

  provider     String   @default("local")
  googleId     String?  @unique
  appleId      String?  @unique

  isEmailVerified Boolean @default(false)
  otps         Otp[]
  
  roleId       String
  role         Role     @relation(fields: [roleId], references: [id])

  vendorStore  Vendor?
  customer     Customer?

  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  users       User[]
  permissions RolePermission[]
}

model Permission {
  id    String           @id @default(uuid())
  name  String           @unique
  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String

  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model Otp {
  id        String   @id @default(uuid())
  userId    String
  otp       String   
  type      String   
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Vendor {
  id              String   @id @default(uuid())
  businessName    String?
  publicEmail     String?
  contactNumber   String?
  bio             String?       @db.Text
  coverImage      String?          
  onboardingStep  Int           @default(1)

  ownerId              String   @unique
  owner                User     @relation(fields:[ownerId], references:[id])
  kycStatus            KycStatus @default(UNVERIFIED)
  
  stripeCustomerId     String?  @unique 
  stripeSubscriptionId String?  @unique 

  subscriptionPlanId   String?
  subscriptionPlan     SubscriptionPlan? @relation(fields:[subscriptionPlanId], references: [id])
  subscriptionStatus   SubscriptionStatus @default(INACTIVE)
  subscriptionExpiry   DateTime?

  kycProfile           KycProfile?
  products             Product[] 
  socialLinks          SocialLink[]
  cuisines             VendorCuisine[]
  operationHours       OperationHour[]
  serviceArea          ServiceArea?
  vendorVerification   VendorVerification?
  categories           Category[]
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model SubscriptionPlan {
  id             String   @id @default(uuid())
  name           String   
  price          Float    
  durationDays   Int      
  maxProducts    Int      

  stripePriceId  String   @unique 

  vendors        Vendor[] 
}

model KycProfile {
  id               String   @id @default(uuid())
  vendorId         String   @unique
  vendor           Vendor   @relation(fields:[vendorId], references: [id])

  documentType     DocumentType
  documentNumber   String   @unique
  frontImageUrl    String
  backImageUrl     String?
  
  submittedAt      DateTime @default(now())
  verifiedAt       DateTime?
}

model Product {
  id                String    @id @default(uuid())
  name              String
  description       String
  price             Float    
  estimateCookTime  Int       @default(10)
  isActive          Boolean   @default(true)

  vendorId          String
  vendor            Vendor    @relation(fields:[vendorId], references: [id])

  categoryId        String?
  category          Category? @relation(fields: [categoryId], references: [id])

  sizeOptions       SizeOption[]
  choiceOptions     ChoiceOption[]
  addOns            AddOn[]
  images            ProductImage[]

  createdAt   DateTime @default(now())
}

model SocialLink {
  id        String   @id @default(uuid())
  url       String?
  vendorId  String
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model Cuisine {
  id      String           @id @default(uuid())
  name    String           @unique
  vendors VendorCuisine[]
}

model VendorCuisine {
  vendorId  String
  cuisineId String
  vendor    Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  cuisine   Cuisine @relation(fields: [cuisineId], references: [id], onDelete: Cascade)

  @@id([vendorId, cuisineId])
}

model OperationHour {
  id        String   @id @default(uuid())

  vendorId  String
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  dayOfWeek  Int                          // 0 = Sunday, 6 = Saturday
  openTime   String?                      // "09:00"
  closeTime  String?                      // "22:00"
  isClosed   Boolean   @default(false)
  activeFrom DateTime
  activeTo   DateTime?    

  priority   Int       @default(0)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([vendorId, dayOfWeek, activeFrom, activeTo])
}

model ServiceArea {
  id        String   @id @default(uuid())
  vendorId  String   @unique
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  latitude  Float
  longitude Float
  address   String?
  radius    Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VendorVerification {
  id                String   @id @default(uuid())
  vendorId          String   @unique
  vendor            Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  
  businessLicense   String
  healthPermit      String
  insuranceProof    String

  status            VerificationStatus @default(PENDING)
  rejectionReason   String?

  submittedAt       DateTime @default(now())
  reviewedAt        DateTime?

  version           Int      @default(1)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([vendorId])
}

model Category {
  id        String   @id @default(uuid())
  name      String
  vendorId  String
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  products  Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([vendorId, name])
}

model SizeOption {
  id        String   @id @default(uuid())
  productId String
  
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  name      String   
  price     Float

  isRequired Boolean @default(false)

  createdAt DateTime @default(now())
}

model ChoiceOption {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  name      String   
  price     Float

  isRequired Boolean @default(false)

  createdAt DateTime @default(now())
}

model AddOn {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  name      String   
  price     Float
  
  isRequired Boolean @default(false)

  createdAt DateTime @default(now())
}

model ProductImage {
  id        String   @id @default(uuid())

  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  url       String
  isPrimary Boolean  @default(false) 
  position  Int      @default(0)     

  createdAt DateTime @default(now())

  @@index([productId])
}

model Customer {
  id            String   @id @default(uuid())

  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  phoneNumber   String?  
  dateOfBirth   DateTime?
  address       String?
  latitude      Float?
  longitude     Float?
  avatar        String?
  isActive      Boolean  @default(true)

  preferredRadius Float? 

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

}

enum VerificationStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
}

enum PaymentMethod {
  COD 
}

enum KycStatus {
  UNVERIFIED
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum DocumentType {
  NATIONAL_ID
  PASSPORT
  DRIVERS_LICENSE
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  CANCELLED
}

