generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String?
  name         String? 

  provider     String   @default("local")
  googleId     String?  @unique
  appleId      String?  @unique

  isEmailVerified Boolean @default(false)
  otps         Otp[]
  
  roleId       String
  role         Role     @relation(fields: [roleId], references: [id])

  vendorStore  Vendor?
  customer     Customer?

  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  users       User[]
  permissions RolePermission[]
}

model Permission {
  id    String           @id @default(uuid())
  name  String           @unique
  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String

  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model Otp {
  id        String   @id @default(uuid())
  userId    String
  otp       String   
  type      String   
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Vendor {
  id                   String   @id @default(uuid())
  businessName         String?
  publicEmail          String?
  contactNumber        String?
  bio                  String?       @db.Text
  coverImage           String?          
  onboardingStep       Int           @default(1)

  ownerId              String   @unique
  owner                User     @relation(fields:[ownerId], references:[id])
  kycStatus            KycStatus @default(UNVERIFIED)
  
  stripeCustomerId     String?  @unique 
  stripeSubscriptionId String?  @unique 

  subscriptionPlanId   String?
  subscriptionPlan     SubscriptionPlan? @relation(fields:[subscriptionPlanId], references: [id])
  subscriptionStatus   SubscriptionStatus @default(INACTIVE)
  subscriptionExpiry   DateTime?

  truckReviewAverage   Float    @default(0)
  truckReviewCount     Int      @default(0)

  kycProfile           KycProfile?
  products             Product[] 
  socialLinks          SocialLink[]
  cuisines             VendorCuisine[]
  operationHours       OperationHour[]
  serviceArea          ServiceArea?
  vendorVerification   VendorVerification?
  categories           Category[]
  orders               Order[]
  favoritedBy          FavoriteVendor[]
  carts                Cart[]
  truckReviews         VendorTruckReview[]
  truckGalleryImages   TruckGalleryImage[]
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model SubscriptionPlan {
  id             String   @id @default(uuid())
  name           String   
  price          Float    
  durationDays   Int      
  maxProducts    Int      

  stripePriceId  String   @unique 

  vendors        Vendor[] 
}

model KycProfile {
  id               String   @id @default(uuid())
  vendorId         String   @unique
  vendor           Vendor   @relation(fields:[vendorId], references: [id])

  documentType     DocumentType
  documentNumber   String   @unique
  frontImageUrl    String
  backImageUrl     String?
  
  submittedAt      DateTime @default(now())
  verifiedAt       DateTime?
}

model Product {
  id                String    @id @default(uuid())
  name              String
  description       String
  price             Float    
  estimateCookTime  Int       @default(10)
  isActive          Boolean   @default(true)

  vendorId          String
  vendor            Vendor    @relation(fields:[vendorId], references: [id])

  categoryId        String?
  category          Category? @relation(fields: [categoryId], references: [id])

  foodReviewAverage Float     @default(0)
  foodReviewCount   Int       @default(0)

  sizeOptions       SizeOption[]
  choiceOptions     ChoiceOption[]
  addOns            AddOn[]
  images            ProductImage[]
  cartItems         CartItem[]
  orderItems        OrderItem[]
  favoritedBy       FavoriteProduct[]
  foodReview        FoodReview[]

  createdAt   DateTime @default(now())
}

model SocialLink {
  id        String   @id @default(uuid())
  url       String?
  vendorId  String
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model Cuisine {
  id      String           @id @default(uuid())
  name    String           @unique
  vendors VendorCuisine[]
}

model VendorCuisine {
  vendorId  String
  cuisineId String
  vendor    Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  cuisine   Cuisine @relation(fields: [cuisineId], references: [id], onDelete: Cascade)

  @@id([vendorId, cuisineId])
}

model OperationHour {
  id        String   @id @default(uuid())

  vendorId  String
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  dayOfWeek  Int                          // 0 = Sunday, 6 = Saturday
  openTime   String?                      // "09:00"
  closeTime  String?                      // "22:00"
  isClosed   Boolean   @default(false)
  activeFrom DateTime
  activeTo   DateTime?    

  priority   Int       @default(0)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([vendorId, dayOfWeek, activeFrom, activeTo])
}

model ServiceArea {
  id        String   @id @default(uuid())
  vendorId  String   @unique
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  latitude  Float
  longitude Float
  address   String?
  radius    Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VendorVerification {
  id                String   @id @default(uuid())
  vendorId          String   @unique
  vendor            Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  
  businessLicense   String
  healthPermit      String
  insuranceProof    String

  status            VerificationStatus @default(PENDING)
  rejectionReason   String?

  submittedAt       DateTime @default(now())
  reviewedAt        DateTime?

  version           Int      @default(1)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([vendorId])
}

model Category {
  id        String   @id @default(uuid())
  name      String
  vendorId  String
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  products  Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([vendorId, name])
}

model SizeOption {
  id        String   @id @default(uuid())

  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  name      String   
  price     Float

  isRequired Boolean @default(false)

  cartItems CartItem[]

  createdAt DateTime @default(now())
}

model ChoiceOption {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  name      String   
  price     Float

  isRequired Boolean @default(false)

  choiceOptions CartItemChoiceOption[]

  createdAt DateTime @default(now())
}

model AddOn {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  name      String   
  price     Float

  isRequired Boolean @default(false)
  cartItems  CartItemAddOn[]

  createdAt  DateTime @default(now())
}

model ProductImage {
  id        String   @id @default(uuid())

  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  url       String
  isPrimary Boolean  @default(false) 
  position  Int      @default(0)     

  createdAt DateTime @default(now())

  @@index([productId])
}

model Customer {
  id            String   @id @default(uuid())

  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  phoneNumber     String?  
  dateOfBirth     DateTime?
  address         String?
  latitude        Float?
  longitude       Float?
  avatar          String?
  isActive        Boolean  @default(true)
  preferredRadius Float? 

  carts            Cart[]
  orders           Order[]
  favoriteProducts FavoriteProduct[]
  favoriteVendors  FavoriteVendor[]
  truckReviews     VendorTruckReview[]
  foodReviews      FoodReview[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Cart {
  id          String     @id @default(uuid())

  customerId  String     
  customer    Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)

  vendorId    String
  vendor      Vendor     @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  items       CartItem[]

  totalAmount Float      @default(0)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([customerId, vendorId])
  @@index([customerId])
  @@index([vendorId])
}

model CartItem {
  id          String   @id @default(uuid())

  cartId      String
  cart        Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId   String
  product     Product  @relation(fields: [productId], references: [id])

  quantity    Int      @default(1)
  price       Float    
  note        String?  @db.Text

  sizeOptionId  String?
  sizeOption    SizeOption? @relation(fields: [sizeOptionId], references: [id])

  choiceOptions CartItemChoiceOption[]
  addOns        CartItemAddOn[]

  createdAt   DateTime @default(now())

  @@index([cartId])
  @@index([productId])
}

model CartItemChoiceOption {
  cartItemId     String
  choiceOptionId String

  cartItem       CartItem     @relation(fields: [cartItemId], references: [id], onDelete: Cascade)
  choiceOption   ChoiceOption @relation(fields: [choiceOptionId], references: [id], onDelete: Cascade)

  @@id([cartItemId, choiceOptionId])
  @@index([choiceOptionId])
}

model CartItemAddOn {
  cartItemId String
  addOnId    String

  cartItem   CartItem @relation(fields: [cartItemId], references: [id], onDelete: Cascade)
  addOn      AddOn    @relation(fields: [addOnId], references: [id], onDelete: Cascade)

  @@id([cartItemId, addOnId])
  @@index([addOnId])
}

model Order {
  id              String        @id @default(uuid())

  orderNumber     String        @unique
  
  customerId      String
  customer        Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)

  vendorId        String
  vendor          Vendor        @relation(fields: [vendorId], references: [id])

  status          OrderStatus   @default(PENDING)
  paymentMethod   PaymentMethod @default(COD)

  subtotal         Float
  tax              Float         @default(0)
  serviceFee       Float         @default(0)
  totalAmount      Float
  note             String?       @db.Text
  estimatedReadyAt DateTime?
  confirmedAt      DateTime?
  preparingAt      DateTime?
  readyAt          DateTime?
  completedAt      DateTime?
  cancelledAt      DateTime?

  orderItems       OrderItem[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([customerId])
  @@index([vendorId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id              String   @id @default(uuid())

  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId       String
  product         Product  @relation(fields: [productId], references: [id])

  productName     String
  quantity        Int
  unitPrice       Float
  sizeName        String?
  sizePrice       Float    @default(0)
  lineTotal       Float
  createdAt       DateTime @default(now())

  orderItemChoiceOption  OrderItemChoiceOption[]
  orderItemAddOn         OrderItemAddOn[]
  foodReview             FoodReview?

  @@index([orderId])
  @@index([productId])
}

model OrderItemChoiceOption {
  id             String    @id @default(uuid())

  orderItemId    String
  orderItem      OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  choiceOptionId String?
  name           String
  price          Float

  @@index([orderItemId])
}

model OrderItemAddOn {
  id          String    @id @default(uuid())

  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  addOnId     String?
  name        String
  price       Float

  @@index([orderItemId])
}

model FavoriteProduct {
  id          String   @id @default(uuid())

  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([customerId, productId]) 
  @@index([customerId])
  @@index([productId])
}

model FavoriteVendor {
  id          String   @id @default(uuid())

  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  vendorId    String
  vendor      Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([customerId, vendorId]) 
  @@index([customerId])
  @@index([vendorId])
}

model VendorTruckReview {
  id          String   @id @default(uuid())

  vendorId    String
  vendor      Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  rating      Int
  reviewText  String?  @db.Text

  images      VendorTruckReviewImage[]
  tags        VendorTruckReviewTagMap[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([vendorId, customerId])
  @@index([vendorId])
  @@index([customerId])
  @@index([createdAt])
}

model VendorTruckReviewImage {
  id        String            @id @default(uuid())

  reviewId  String
  review    VendorTruckReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  imageUrl  String
  position  Int               @default(0)

  createdAt DateTime          @default(now())

  @@index([reviewId])
}

model VendorTruckReviewTag {
  id       String                    @id @default(uuid())
  name     String                    @unique

  reviews  VendorTruckReviewTagMap[]
}

model VendorTruckReviewTagMap {
  reviewId String
  tagId    String

  review   VendorTruckReview     @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  tag      VendorTruckReviewTag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([reviewId, tagId])
  @@index([tagId])
}

model TruckGalleryImage {
  id         String   @id @default(uuid())

  vendorId   String
  vendor     Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  url        String
  caption    String?
  isPrimary  Boolean  @default(false)
  position   Int      @default(0)

  createdAt  DateTime @default(now())

  @@index([vendorId])
}

model FoodReview {
  id          String   @id @default(uuid())

  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  rating      Int
  reviewText  String?  @db.Text

  images      FoodReviewImage[]
  tags        FoodReviewTagMap[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([orderItemId])
  @@index([productId])
  @@index([customerId])
  @@index([createdAt])
}

model FoodReviewImage {
  id        String     @id @default(uuid())

  reviewId  String
  review    FoodReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  imageUrl  String
  position  Int        @default(0)

  createdAt DateTime   @default(now())

  @@index([reviewId])
}

model FoodReviewTag {
  id       String             @id @default(uuid())
  name     String             @unique

  reviews  FoodReviewTagMap[]
}

model FoodReviewTagMap {
  reviewId String
  tagId    String

  review   FoodReview    @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  tag      FoodReviewTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([reviewId, tagId])
  @@index([tagId])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY_FOR_PICKUP
  COMPLETED
  CANCELLED
}

enum VerificationStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
}

enum PaymentMethod {
  COD
  STRIPE
  APPLE_PAY
  GOOGLE_PAY
}

enum KycStatus {
  UNVERIFIED
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum DocumentType {
  NATIONAL_ID
  PASSPORT
  DRIVERS_LICENSE
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  CANCELLED
}

